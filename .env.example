# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Google Gemini API (FREE — no credit card needed)
# Get your key at: https://aistudio.google.com/apikey  (takes 2 minutes)
GEMINI_API_KEY=your-gemini-api-key-here

# MongoDB Atlas (FREE M0 cluster)
# Sign up at: https://cloud.mongodb.com → New Project → Build a Database → Free M0
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/opticai?retryWrites=true&w=majority

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── OPTIONAL (for frame image hosting) ─────────────────────────────────────
# Cloudinary FREE tier: 25GB storage, 25GB bandwidth/month
# Sign up at: https://cloudinary.com → Free plan
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── REMOVED (no longer needed) ─────────────────────────────────────────────
# ANTHROPIC_API_KEY  ← replaced by Gemini (free)
# STABILITY_API_KEY  ← replaced by Gemini image gen (free)
